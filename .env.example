# beat-this sidecar — standalone deployment config.
#
# Copy to `.env` and set MUSIC_DIR. Everything else is optional.
#   cp .env.example .env

# REQUIRED. Directory on the host that holds the audio files. Mounted
# read-only at /music inside the container. Request paths in POST
# /analyze are resolved relative to this root.
MUSIC_DIR=./music

# Host port the service is published on. The container always listens
# on 8000 internally.
# BEATTHIS_HOST_PORT=8000

# beat-this checkpoint to load. "final0" is the default released model
# and is baked into the image at build time. Changing this triggers a
# checkpoint download on first request.
# BEATTHIS_CHECKPOINT=final0

# Torch device. "cpu" works everywhere; set to "cuda" if you have an
# NVIDIA GPU AND rebuild the image against a CUDA torch wheel (the
# default Dockerfile installs the CPU-only build).
# BEATTHIS_DEVICE=cpu
